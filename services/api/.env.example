DATABASE_URL=postgresql://contourcast:contourcast@localhost:5432/contourcast
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=4
DATABASE_POOL_MAX_WAITING=8
DATABASE_POOL_TIMEOUT_SECONDS=3
DATABASE_SITE_CACHE_SECONDS=60
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,https://castingcompass.com
DATA_ROOT=/absolute/path/to/contourcast
PORT=8000
