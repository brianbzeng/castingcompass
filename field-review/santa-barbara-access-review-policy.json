    "responseLocation": "private_outside_repository",
    "repositoryState": "blank_policy_and_aggregate_receipt_only",
    "rawResponseRetentionDaysAfterDecision": 30,
    "privateEvidenceDigestRequiredForAggregateReceipt": true
  },
  "allowedPrivateResponseFields": [
    "site_id",
    "response_id",
    "observed_month",
    "question_answers",
    "correction_category",
    "generalized_correction"
  ],
  "prohibitedFields": [
    "reviewer_name",
    "contact_information",
    "account_or_user_id",
    "exact_visit_timestamp",
    "precise_coordinates",
    "catch_or_trip_outcomes",
    "trip_notes",
    "photos_or_video",
    "credentials_or_tokens",
    "private_access_directions"
  ],
