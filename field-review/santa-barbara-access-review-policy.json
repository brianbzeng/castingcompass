    "matches_catalog",
    "correction_needed",
    "not_observed",
    "uncertain"
  ],
  "questions": [
    {
      "id": "public_entry_route",
      "prompt": "Did the public entry route and shoreline access match the catalog description?"
    },
    {
      "id": "access_status",
      "prompt": "Did posted access information match the catalog status during the month you checked?"
    },
    {
      "id": "parking_walk",
      "prompt": "Did the parking or transit and walking description match what was generally available?"
    },
    {
      "id": "posted_restrictions",
      "prompt": "Did the catalog caveat account for the posted closures or use restrictions you observed?"
    },
    {
      "id": "boundary_clarity",
      "prompt": "Was the described fishing area and exclusion boundary clear enough to follow without entering excluded water?"
    }
  ],
  "acceptance": {
    "minimumDistinctReviewersAcrossRegion": 2,
    "minimumReviewsForOpenSite": 1,
    "minimumReviewsForLimitedSite": 2,
    "officialSourceRecheckWithinDays": 7,
    "maximumUnresolvedCorrections": 0,
    "deploymentAuthorizationGranted": false,
    "modelValidationEvidenceGranted": false,
    "safetyOrLegalityGuaranteeGranted": false
  },
