      "properties": {
        "frozen_artifact_edited_in_place": { "const": false },
        "semantic_change_requires_new_version": { "const": true },
        "activation_manifest_can_change_protocol_semantics": { "const": false },
        "post_outcome_change_can_reclassify_pilot_rows_as_confirmatory": { "const": false }
      }
