            "participant-clustered-uncertainty",
            "precommitted-complete-attempt-inclusion",
            "score-influence-stratification",
            "minimum-positive-negative-and-participant-support",
            "negative-and-inconclusive-reporting",
            "promotion-drift-and-rollback-gates",
            "separate-timestamped-preregistration-before-confirmatory-enrollment"
          ]
        },
        "promotion_before_confirmatory_pass_allowed": { "const": false }
      }
