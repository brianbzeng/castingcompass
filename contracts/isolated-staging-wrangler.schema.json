{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "castingcompass.isolated-staging-wrangler/1.0.0",
  "title": "CastingCompass isolated-staging resolved Wrangler configuration manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "main",
    "compatibility_date",
    "compatibility_flags",
    "workers_dev",
    "vars",
    "ratelimits",
    "version_metadata",
    "routes",
    "no_bundle",
    "rules",
    "assets",
    "d1_databases",
    "services",
    "observability"
  ],
  "properties": {
    "schema_version": { "const": "castingcompass.isolated-staging-wrangler/1.0.0" },
    "name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "main": { "type": "string", "minLength": 1, "maxLength": 256 },
    "compatibility_date": { "type": "string", "format": "date" },
    "compatibility_flags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 64 }
    },
    "workers_dev": { "const": false },
    "vars": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "PUBLIC_DISCUSSIONS_ENABLED",
        "TRIP_PHOTO_UPLOADS_ENABLED",
        "TURNSTILE_ENABLED",
        "RATE_LIMITING_ENABLED",
        "AI_REVIEW_QUEUE_ENABLED",
        "PRIVACY_EXPORT_QUEUE_ENABLED",
        "RELEASE_MAINTENANCE_MODE",
        "AI_REVIEW_EXERCISE_ID",
        "AI_REVIEW_EXERCISE_ACCOUNT_HASH",
        "AI_REVIEW_EXERCISE_PROVIDER_VERSION_ID",
        "SECURITY_EXERCISE_ID"
      ],
      "properties": {
        "PUBLIC_DISCUSSIONS_ENABLED": { "const": "false" },
        "TRIP_PHOTO_UPLOADS_ENABLED": { "const": "false" },
        "TURNSTILE_ENABLED": { "const": "false" },
        "RATE_LIMITING_ENABLED": { "const": "true" },
        "AI_REVIEW_QUEUE_ENABLED": { "enum": ["false", "true"] },
        "PRIVACY_EXPORT_QUEUE_ENABLED": { "const": "false" },
        "RELEASE_MAINTENANCE_MODE": { "const": "false" },
        "AI_REVIEW_EXERCISE_ID": { "$ref": "#/$defs/exerciseId" },
        "AI_REVIEW_EXERCISE_ACCOUNT_HASH": { "$ref": "#/$defs/hash" },
        "AI_REVIEW_EXERCISE_PROVIDER_VERSION_ID": { "$ref": "#/$defs/workerVersion" },
        "SECURITY_EXERCISE_ID": { "$ref": "#/$defs/exerciseId" }
      }
    },
    "ratelimits": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "namespace_id", "simple"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 64 },
          "namespace_id": { "type": "string", "pattern": "^[0-9]{1,32}$" },
          "simple": {
            "type": "object",
            "additionalProperties": false,
            "required": ["limit", "period"],
            "properties": {
              "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
              "period": { "type": "integer", "minimum": 1, "maximum": 86400 }
            }
          }
        }
      }
    },
    "version_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding"],
      "properties": { "binding": { "type": "string", "minLength": 1, "maxLength": 64 } }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "custom_domain"],
        "properties": {
          "pattern": { "type": "string", "minLength": 4, "maxLength": 253 },
          "custom_domain": { "const": true }
        }
      }
    },
    "no_bundle": { "const": true },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "globs"],
        "properties": {
          "type": { "const": "ESModule" },
          "globs": { "const": ["**/*.js", "**/*.mjs"] }
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["directory", "binding"],
      "properties": {
        "directory": { "type": "string", "minLength": 1, "maxLength": 256 },
        "binding": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "d1_databases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["binding", "database_name", "database_id", "migrations_dir"],
        "properties": {
          "binding": { "const": "DB" },
          "database_name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,127}-isolated-staging$" },
          "database_id": { "$ref": "#/$defs/uuid" },
          "migrations_dir": { "const": "drizzle" }
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["binding", "service"],
        "properties": {
          "binding": { "type": "string", "minLength": 1, "maxLength": 64 },
          "service": { "type": "string", "minLength": 1, "maxLength": 128 }
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "logs"],
      "properties": {
        "enabled": { "const": true },
        "logs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["invocation_logs", "head_sampling_rate"],
          "properties": {
            "invocation_logs": { "const": false },
            "head_sampling_rate": { "const": 1 }
          }
        }
      }
    },
    "queues": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producers", "consumers"],
      "properties": {
        "producers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["binding", "queue"],
            "properties": {
              "binding": { "type": "string", "minLength": 1, "maxLength": 64 },
              "queue": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        },
        "consumers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["queue", "max_batch_size", "max_batch_timeout", "max_retries", "max_concurrency", "dead_letter_queue"],
            "properties": {
              "queue": { "type": "string", "minLength": 1, "maxLength": 128 },
              "max_batch_size": { "type": "integer", "minimum": 1, "maximum": 100 },
              "max_batch_timeout": { "type": "integer", "minimum": 0, "maximum": 60 },
              "max_retries": { "type": "integer", "minimum": 0, "maximum": 100 },
              "max_concurrency": { "type": "integer", "minimum": 1, "maximum": 100 },
              "dead_letter_queue": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "vars": {
            "type": "object",
            "properties": { "AI_REVIEW_QUEUE_ENABLED": { "const": "true" } },
            "required": ["AI_REVIEW_QUEUE_ENABLED"]
          }
        },
        "required": ["vars"]
      },
      "then": { "properties": { "queues": {} }, "required": ["queues"] },
      "else": { "not": { "required": ["queues"] } }
    }
  ],
  "$defs": {
    "exerciseId": { "type": "string", "pattern": "^sec_[a-f0-9]{32}$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "workerVersion": { "type": "string", "pattern": "^[A-Za-z0-9-]{1,128}$" },
    "uuid": { "type": "string", "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-[1-5][a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$" }
  }
}
