{
  "name": "castingcompass",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.23.1 <23",
    "npm": "10.9.8"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:cloudflare": "CASTINGCOMPASS_CLOUDFLARE_BUILD=1 NEXT_PUBLIC_PHOTO_UPLOADS=false NEXT_PUBLIC_API_URL= npm run build",
    "verify:release-checkout": "node scripts/verify-release-checkout.mjs --root . --expected-commit \"$RELEASE_COMMIT\"",
    "verify:production-change": "node scripts/verify-production-change-authorization.mjs verify --root . --expected-commit \"$RELEASE_COMMIT\" --expected-gate-commit \"$RELEASE_COMMIT\" --authorization-file \"$RELEASE_AUTHORIZATION_FILE\"",
    "deploy:cloudflare": "npm run release:cloudflare",
    "deploy:cloudflare:worker-only": "npm run release:cloudflare",
    "preflight:cloudflare:remote": "node scripts/integrated-release.mjs preflight",
    "reconcile:cloudflare:0007": "node scripts/integrated-release.mjs reconcile-0007",
    "migrate:cloudflare:remote": "node scripts/integrated-release.mjs apply --migration \"$RELEASE_MIGRATION\"",
    "postflight:cloudflare:remote": "node scripts/integrated-release.mjs postflight",
    "verify:release-maintenance": "node scripts/verify-release-maintenance.mjs",
    "release:cloudflare": "node scripts/release-cloudflare.mjs --mode normal --release-root . --expected-commit \"$RELEASE_COMMIT\" --expected-gate-commit \"$RELEASE_COMMIT\" --authorization-file \"$RELEASE_AUTHORIZATION_FILE\"",
    "release:cloudflare:maintenance": "node scripts/release-cloudflare.mjs --mode maintenance --release-root . --expected-commit \"$RELEASE_COMMIT\" --expected-gate-commit \"$RELEASE_COMMIT\" --authorization-file \"$RELEASE_AUTHORIZATION_FILE\"",
    "release:cloudflare:safety-floor": "node scripts/release-cloudflare.mjs --mode safety-floor --release-root \"$RELEASE_ROOT\" --expected-commit \"$RELEASE_COMMIT\" --expected-gate-commit \"$RELEASE_GATE_COMMIT\" --authorization-file \"$RELEASE_AUTHORIZATION_FILE\"",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build:cloudflare && node --test tests/*.test.mjs",
    "test:mobile": "playwright test tests/mobile-viewport.spec.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "security": "npm run security:secrets && npm run security:npm-install-policy && npm run security:python-locks && npm run security:dependencies && npm run security:sbom && npm run security:release-sbom && npm run security:exercise-policy && npm run security:cloudflare-provider-state && npm run security:production-change-policy && npm run security:ai-review-queue-policy && npm run security:mobile-readiness && npm run security:authorship-provenance",
    "security:npm-install-policy": "node scripts/verify-npm-install-policy.mjs",
    "security:dependencies": "npm audit --audit-level=high && npm audit --omit=dev --audit-level=moderate",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:python-locks": "node scripts/generate-python-locks.mjs --check",
    "security:python-locks:write": "node scripts/generate-python-locks.mjs --write",
    "security:sbom": "node scripts/generate-sbom.mjs --check",
    "security:sbom:write": "node scripts/generate-sbom.mjs --write",
    "security:release-sbom": "node scripts/generate-release-sbom.mjs --check",
    "security:release-sbom:write": "node scripts/generate-release-sbom.mjs --write",
    "security:exercise-policy": "node scripts/security-exercise.mjs verify-policy",
    "security:exercise-plan": "node scripts/security-exercise.mjs plan",
    "security:exercise-run": "node scripts/security-exercise.mjs run",
    "security:cloudflare-provider-state": "node scripts/audit-cloudflare-provider-state.mjs verify-policy",
    "security:production-change-policy": "node scripts/verify-production-change-authorization.mjs verify-policy",
    "audit:cloudflare:state": "node scripts/audit-cloudflare-provider-state.mjs audit-live",
    "security:ai-review-queue-policy": "node scripts/verify-ai-review-queue-policy.mjs",
    "security:mobile-readiness": "node scripts/verify-mobile-readiness.mjs",
    "security:authorship-provenance": "node scripts/verify-authorship-provenance.mjs --check",
    "security:authorship-provenance:write": "node scripts/verify-authorship-provenance.mjs --write",
    "ai-review-queue:plan-replay": "node scripts/ai-review-queue-operator.mjs plan-replay",
    "load:smoke": "node scripts/load-test.mjs --profile smoke",
    "load:test": "node scripts/load-test.mjs",
    "drill:restore:offline": "node scripts/run-operational-restore-drill.mjs",
    "verify:privacy-rights": "node scripts/privacy-rights-case.mjs verify-policy",
    "drill:privacy-rights:offline": "node scripts/privacy-rights-case.mjs drill",
    "verify:discussion-safety": "node scripts/verify-discussion-safety.mjs",
    "verify:validation-successor": "node scripts/verify-validation-successor.mjs",
    "data:refresh": "PYTHONPATH=. python3 scripts/generate_snapshot.py && PYTHONPATH=. python3 scripts/generate_opportunity_attestations.py",
    "api:test": "python3 -m pytest services/api/tests -q"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "maplibre-gl": "5.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.26",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.7",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    },
    "js-yaml": "4.3.0",
    "postcss": "8.5.14"
  },
  "type": "module"
}
