{
  "name": "castingcompass",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:cloudflare": "CASTINGCOMPASS_CLOUDFLARE_BUILD=1 NEXT_PUBLIC_PHOTO_UPLOADS=false NEXT_PUBLIC_API_URL= npm run build",
    "verify:release-checkout": "node scripts/verify-release-checkout.mjs --root . --expected-commit \"$RELEASE_COMMIT\"",
    "deploy:cloudflare": "npm run release:cloudflare",
    "deploy:cloudflare:worker-only": "npm run release:cloudflare",
    "migrate:cloudflare:remote": "npm run verify:release-checkout && wrangler d1 migrations apply contourcast-trips --remote --config wrangler.jsonc",
    "release:cloudflare": "npm run verify:release-checkout && npm run build:cloudflare && wrangler deploy --config wrangler.jsonc",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build:cloudflare && node --test tests/*.test.mjs",
    "test:mobile": "playwright test tests/mobile-viewport.spec.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit",
    "security": "npm run security:secrets",
    "security:secrets": "node scripts/check-secrets.mjs",
    "verify:discussion-safety": "node scripts/verify-discussion-safety.mjs",
    "data:refresh": "python3 scripts/generate_snapshot.py",
    "api:test": "python3 -m pytest services/api/tests -q"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "ajv": "^8.20.0",
    "ajv-formats": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.111.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "type": "module"
}
