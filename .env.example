# Public FastAPI base URL, without a trailing slash. Leave unset to use the
# checked-in offline-capable forecast snapshot.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set false for a Cloudflare account without R2 and Cloudflare Images enabled.
# Trip reports remain available; only optional verification photos are hidden.
NEXT_PUBLIC_PHOTO_UPLOADS=false

# FastAPI / PostGIS configuration (used by services/api).
DATABASE_URL=postgresql://contourcast:contourcast@localhost:5432/contourcast
ALLOWED_ORIGINS=http://localhost:3000
# Transactional account email (Resend)
RESEND_API_KEY=
AUTH_EMAIL_FROM="CastingCompass <account@castingcompass.com>"

# Cloudflare Turnstile account-form protection. Runtime configuration is
# served by the Worker; the browser never receives the secret key.
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=castingcompass.com

# Optional advisory trip-review model (Xiaomi MiMo)
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5

# Dedicated HMAC material for short-lived log correlation. Never reuse the
# rate-limit, validation, provider, session, deployment, or backup keys.
OBSERVABILITY_PSEUDONYM_SECRET=
LOG_LEVEL=info
